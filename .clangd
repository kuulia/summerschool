---
If:
  PathMatch: .*/gpu/exercises/.*-omp-.*\.(cpp|cc)$
CompileFlags:
  Add:
    - -I/opt/rocm-6.3.4/include
    - -I/usr/lib/x86_64-linux-gnu/openmpi/include
    - -I/usr/lib/gcc/x86_64-linux-gnu/13/include
    - -fopenmp
    - -fopenmp-targets=amdgcn-amd-amdhsa
---
If:
  PathMatch: .*/gpu/exercises/.*\.(cpp|cc|cu)$
CompileFlags:
  Add:
    - -I/opt/rocm-6.3.4/include
    - -I/opt/rocm-6.3.4/include/hip
    - -I/usr/lib/x86_64-linux-gnu/openmpi/include
    - -I/usr/lib/gcc/x86_64-linux-gnu/13/include
    - -fopenmp
    - -D__HIP_PLATFORM_AMD__
    - -D__AMDGCN_WAVEFRONT_SIZE=64
    - -x
    - hip
    - -nogpulib
---
CompileFlags:
  Add:
    - -I/usr/lib/x86_64-linux-gnu/openmpi/include
    - -I/usr/lib/gcc/x86_64-linux-gnu/13/include
    - -fopenmp

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  Designators: Yes

Diagnostics:
  UnusedIncludes: Strict
  MissingIncludes: Strict
  ClangTidy:
    Add:
      - bugprone*
      - performance*
      - portability*

Index:
  Background: Build
