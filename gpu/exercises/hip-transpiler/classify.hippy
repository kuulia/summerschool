kernel classify(values: float*, results: int*, n: int):
    i = global_index()
    if i < n:
        if values[i] < 0:
            results[i] = -1
        elif values[i] == 0:
            results[i] = 0
        else:
            results[i] = 1

kernel zero_init(data: float*, n: int):
    for j in range(n):
        data[j] = 0.0

buffer float values(N), data(N)
buffer int results(N)
upload values
launch classify(N)(values, results, n)
download results
